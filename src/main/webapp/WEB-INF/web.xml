<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Staff Check In/Out Application</display-name>

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- Database Configuration -->
    <context-param>
        <param-name>dbUrl</param-name>
        <param-value>jdbc:sqlserver://localhost:1433;databaseName=StaffAttendance;encrypt=true;trustServerCertificate=true</param-value>
    </context-param>
    <context-param>
        <param-name>dbUser</param-name>
        <param-value>sa</param-value>
    </context-param>
    <context-param>
        <param-name>dbPassword</param-name>
        <param-value>your_password</param-value>
    </context-param>
    <context-param>
        <param-name>dbDriver</param-name>
        <param-value>com.microsoft.sqlserver.jdbc.SQLServerDriver</param-value>
    </context-param>

    <!-- Servlet Mappings -->
    <servlet>
        <servlet-name>DashboardServlet</servlet-name>
        <servlet-class>com.staffattendance.servlet.DashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DashboardServlet</servlet-name>
        <url-pattern>/dashboard</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>StaffServlet</servlet-name>
        <servlet-class>com.staffattendance.servlet.StaffServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StaffServlet</servlet-name>
        <url-pattern>/staff</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>CheckInServlet</servlet-name>
        <servlet-class>com.staffattendance.servlet.CheckInServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CheckInServlet</servlet-name>
        <url-pattern>/checkin</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>CheckOutServlet</servlet-name>
        <servlet-class>com.staffattendance.servlet.CheckOutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CheckOutServlet</servlet-name>
        <url-pattern>/checkout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RecordsServlet</servlet-name>
        <servlet-class>com.staffattendance.servlet.RecordsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RecordsServlet</servlet-name>
        <url-pattern>/records</url-pattern>
    </servlet-mapping>
</web-app>